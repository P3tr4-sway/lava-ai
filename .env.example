# Server
PORT=3001
NODE_ENV=development

# LLM Provider: "claude" | "openai"
LLM_PROVIDER=claude

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (optional)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.1
# Optional: use an OpenAI-compatible gateway/proxy
# OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1

# Tencent VOD AIGC (optional, OpenAI-compatible via token exchange)
# When these are set, the server will create an ApiToken with TC3 signing
# and call the VOD chat/completions endpoint automatically.
# TENCENT_VOD_SECRET_ID=AKID...
# TENCENT_VOD_SECRET_KEY=...
# TENCENT_VOD_SUB_APP_ID=1234567890
TENCENT_VOD_CHAT_BASE_URL=https://text-aigc.vod-qcloud.com/v1

# DB
DATABASE_URL=./data/lava.db

# CORS
CLIENT_ORIGIN=http://localhost:5173
